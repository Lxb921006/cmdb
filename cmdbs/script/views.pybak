# 修改服务器信息
@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def edit_servers(request):
    data_list = request.POST.get('data', None)
    message = {'status': 'success'}
    if data_list:
        r_data = json.loads(data_list)
        project, ip, ram, cpu, disk, os = r_data
        check_ip = Servers.objects.filter(ip=ip).count()
        if check_ip != 1:
            message['status'] = 'please add server first!'
        else:
            db_project = Servers.objects.filter(ip=ip).values('project')
            if db_project[0]['project'] != project:
                Servers.objects.filter(ip=ip).update(project=project)

            db_ram = Servers.objects.filter(ip=ip).values('ram')
            if db_ram[0]['ram'] != int(ram):
                Servers.objects.filter(ip=ip).update(ram=int(ram))

            db_cpu = Servers.objects.filter(ip=ip).values('cpu')
            if db_cpu[0]['cpu'] != int(cpu):
                Servers.objects.filter(ip=ip).update(cpu=int(cpu))

            db_disk = Servers.objects.filter(ip=ip).values('hard_disk')
            if db_disk[0]['hard_disk'] != int(disk):
                Servers.objects.filter(ip=ip).update(hard_disk=int(disk))

            db_os = Servers.objects.filter(ip=ip).values('os')
            if db_os[0]['os'] != os:
                Servers.objects.filter(ip=ip).update(os=os)
    else:
        message['status'] = 'No data received.'

    return JsonResponse(message)


@login_required(login_url='/cmdb/is_login/')
def user_page(request):
    user_type = {}
    all_info = User.objects.filter(id__gte=1).values('username')
