@login_required(login_url='/cmdb/is_login/')
def platform_base_page(request):  # 基础数据展示
    server_project_list = list()
    platform_project_list = list()
    server = Servers.objects.values("project")
    platforms = Item.objects.values("project")
    for p_item in platforms:
        p_item_name = p_item
        platform_project_list.append(p_item_name.get('project', None))
    for item in server:
        project_all = item
        server_project_list.append(project_all.get('project', None))
    for project_name in set(server_project_list):
        flag = 0
        for all_project in server_project_list:
            if project_name == all_project:
                flag += 1
        if project_name in platform_project_list:
            p_count_res = Item.objects.filter(project=project_name).values('servers_count')
            if p_count_res[0].get('servers_count') != flag:
                Item.objects.filter(project=project_name).update(servers_count=flag)
        else:
            add_p = Item(
                project=project_name,
                desc='game',
                servers_count=flag
            )
            add_p.save()
    all_record_log_data = Item.objects.all()[0:10]
    total_number = Item.objects.all().count()
    total_page = divmod(total_number, 10)
    if total_page[1] == 0:
        total_page = total_page[0]
    else:
        total_page = total_page[0] + 1
    msg = {'data_info': all_record_log_data,
           'total_number': total_number,
           'total_page': total_page}
    return render(request, 'cmdbs/platform_oprations.html', msg)


@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def platform_img(request):
    projects = request.POST.get('data', None)
    platforms_list = []
    servers_number_list = []
    all_datas = []
    print(11111111111111111111111)
    project = Item.objects.values(projects)
    for i in project:
        project_name = i.get('project', None)
        server_object = Item.objects.filter(project=project_name).values('servers_count')
        server_number = server_object[0].get('servers_count')
        datas = {'value': server_number, 'name': project_name}
        all_datas.append(datas)
        platforms_list.append(project_name)
        servers_number_list.append(server_number)
    return JsonResponse({'platform_name': platforms_list, 'platform_number': servers_number_list, 'all_data': all_datas})


@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def platform_show_ajax(request):
    recv_cur_page_number = request.POST.get('cur_page', None)
    recv_change_page_number = request.POST.get('change_page_number', None)
    search_data = request.POST.get('search_data', None)
    jump_page = request.POST.get('jump_page', None)
    change_page_number = common.try_int(recv_change_page_number, 10)
    recv_cur_page_number = common.try_int(recv_cur_page_number, 1)
    data_list = list()
    show_datas = None
    all_datas_count = None
    pages = None
    if all([recv_cur_page_number, recv_change_page_number]):
        all_datas_count = Item.objects.filter(Q(project__icontains=search_data) |
                                              Q(desc__icontains=search_data)
                                              ).count()
        if all_datas_count == 0:
            all_datas_count = 1
        pages = divmod(all_datas_count, change_page_number)
        if pages[1] == 0:
            pages = pages[0]
        else:
            pages = pages[0] + 1
        real_cur_page_number = (common.try_int(recv_cur_page_number, 0) - 1) * change_page_number
        real_change_page_number = common.try_int(recv_cur_page_number, 0) * change_page_number
        if common.try_int(recv_cur_page_number, 0) > pages:
            real_cur_page_number = (pages - 1) * change_page_number
            real_change_page_number = pages * change_page_number
        if real_change_page_number > all_datas_count:
            real_change_page_number = all_datas_count
        show_datas = Item.objects.filter(Q(project__icontains=search_data) |
                                         Q(desc__icontains=search_data))[
                     real_cur_page_number:real_change_page_number]
    if all([jump_page, recv_change_page_number]):
        all_datas_count = Item.objects.filter(Q(project__icontains=search_data) |
                                              Q(desc__icontains=search_data)).count()
        if all_datas_count == 0:
            all_datas_count = 1
        pages = divmod(all_datas_count, change_page_number)
        if pages[1] == 0:
            pages = pages[0]
        else:
            pages = pages[0] + 1
        real_cur_page_number = (common.try_int(jump_page, 0) - 1) * change_page_number
        real_change_page_number = common.try_int(jump_page, 0) * change_page_number
        if common.try_int(recv_cur_page_number, 0) > pages:
            real_cur_page_number = (pages - 1) * change_page_number
            real_change_page_number = pages * change_page_number
        if real_change_page_number > all_datas_count:
            real_change_page_number = all_datas_count
        show_datas = Item.objects.filter(Q(project__icontains=search_data) |
                                         Q(desc__icontains=search_data))[
                     real_cur_page_number:real_change_page_number]

    for item in range(len(show_datas)):
        data_list.append({"project": show_datas[item].project,
                          "desc": show_datas[item].desc,
                          "servers_count": show_datas[item].servers_count,
                          })
    return JsonResponse({'total_number': all_datas_count, 'data_info': data_list, 'total_pages': pages})


# 添加平台
@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def add_platform(request):
    if request.method == 'POST':
        server_info = request.POST.get('data', None)
        msg = {'status': 'success'}
        if not isinstance(json.loads(server_info), list):
            msg['status'] = 'add platform failure.'
        else:
            project, desc = json.loads(server_info)
            try:
                check = Item.objects.filter(project=project).count()
            except:
                msg['status'] = 'check mysql failed.'
            else:
                if check == 0:
                    try:
                        add_platforms = Item(project=project, desc=desc, servers_count=0)
                        add_platforms.save()
                    except:
                        msg['status'] = '%s already exists.' % project
                else:
                    msg['status'] = '%s already exists.' % project
            public_method.Opratings_log(
                                        request.user,
                                        'add platform {}'.format(project),
                                        datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                    )
        return JsonResponse(msg)
    return render(request, 'cmdbs/add_platform.html')


