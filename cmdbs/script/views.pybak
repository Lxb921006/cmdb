            real_change_page_number = pages * change_page_number
        if real_change_page_number > all_datas_count:
            real_change_page_number = all_datas_count
            show_datas = User.objects.filter(Q(username__icontains=search_data) |
                                             Q(email__icontains=search_data) |
                                             Q(is_active__icontains=search_data))[
                                                                           real_cur_page_number:real_change_page_number]

    if all([jump_page, recv_change_page_number]):
        all_datas_count = User.objects.filter(Q(username__icontains=search_data) |
                                              Q(email__icontains=search_data) |
                                              Q(is_active__icontains=search_data)).count()
        if all_datas_count == 0:
            all_datas_count = 1
        pages = divmod(all_datas_count, change_page_number)
        if pages[1] == 0:
            pages = pages[0]
        else:
            pages = pages[0] + 1
        real_cur_page_number = (common.try_int(jump_page, 0) - 1) * change_page_number
        real_change_page_number = common.try_int(jump_page, 0) * change_page_number
        if common.try_int(recv_cur_page_number, 0) > pages:
            real_cur_page_number = (pages - 1) * change_page_number
            real_change_page_number = pages * change_page_number
        if real_change_page_number > all_datas_count:
            real_change_page_number = all_datas_count
            show_datas = User.objects.filter(Q(username__icontains=search_data) |
                                             Q(email__icontains=search_data) |
                                             Q(is_active__icontains=search_data))[
                                                                           real_cur_page_number:real_change_page_number]
    for item in range(len(show_datas)):
        data_list.append({"username": show_datas[item].username,
                          "email": show_datas[item].email,
                          "is_active": show_datas[item].is_active,
                          "date_joined": show_datas[item].date_joined,
                          })
    return JsonResponse({'total_number': all_datas_count, 'data_info': data_list, 'total_pages': pages, "user_type": user_type})


@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def add_del_edit_user(request):
    user = request.POST.get('username', None)
    email = request.POST.get('email', None)
    password = request.POST.get('password', None)
    user_type = request.POST.get('usertype', None)
    action = request.POST.get('action', None)
    msg = {'status': 'success'}

    # 添加账户
    if action == 'add_user':
        check_user = User.objects.filter(username=user)
        if check_user.__len__() != 0:
            msg['status'] = '用户已存在'
        else:
            try:
                recv_group = Group.objects.filter(name=user_type)[0]
                User.objects.create_user(username=user, email=email, password=password)
                add_user = User.objects.filter(username=user)[0]
                add_user.groups.add(recv_group)
            except:
                msg['status'] = '添加失败'
        public_method.Opratings_log(request.user,
                                  'add user {}'.format(check_user),
                                  datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                  )

    # 删除账户
    if action == 'delete':
        if isinstance(json.loads(user), list):
            for u in json.loads(user):
                del_u = User.objects.filter(username=u)[0]
                if del_u.groups.values('name').__len__() > 0:
                    del_g_n = del_u.groups.values('name')[0]['name']
                    _del_g = Group.objects.filter(name=del_g_n)[0]
                    try:
                        del_u.groups.remove(_del_g)
                        User.objects.filter(username=u).delete()
                    except:
                        msg['status'] = '删除失败'
                    public_method.Opratings_log(request.user,
                                              'delete user {}'.format(del_u),
                                              datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                              )
        else:
            del_u = User.objects.filter(username=json.loads(user))[0]
            recv_group = Group.objects.filter(name=user_type)[0]
            try:
                del_u.groups.remove(recv_group)
                User.objects.filter(username=json.loads(user)).delete()
            except:
                msg['status'] = '删除失败'
            public_method.Opratings_log(request.user,
                                      'delete user {}'.format(del_u),
                                      datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                      )

    # 账户启用
    if action == 'enable':
        try:
            update = User.objects.filter(username=user).values('is_active')
            if update[0]['is_active']:
                msg['status'] = '用户已经是启用状态'
            else:
                try:
                    User.objects.filter(username=user).update(is_active=1)
                except:
                    msg['status'] = '用户启用失败'
        except:
            msg['status'] = '用户启用失败'
        else:
            public_method.Opratings_log(request.user,
                                      'enable user {}'.format(user),
                                      datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                      )


    # 账户禁用
    if action == 'disable':
        try:
            update = User.objects.filter(username=user).values('is_active')
            if not update[0]['is_active']:
                msg['status'] = '用户已经是禁用状态'
            else:
                try:
                    User.objects.filter(username=user).update(is_active=0)
                except:
                    msg['status'] = '用户禁用失败'
        except:
            msg['status'] = '用户禁用失败'
        else:
            public_method.Opratings_log(request.user,
                                      'disable user {}'.format(user),
                                      datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                      )

    # 修改密码
    if action == 'change_password':
        try:
            user_set = User.objects.get(username=user)
        except:
            msg['status'] = '用户不存在'
        else:
            recv_group = Group.objects.filter(name=user_type)[0]
            group_info = [g_name.get('name') for g_name in Group.objects.filter(id__gte=1).values('name')]
            try:
                for gs in group_info:
                    del_g = Group.objects.filter(name=gs)[0]
                    if user_set.groups.values('name')[0]['name'] and del_g != user_type:
                        user_set.groups.remove(del_g)
                        user_set.groups.add(recv_group)
                User.objects.filter(username=user).update(email=email)
                user_set.set_password(password)
                user_set.save()
            except:
                msg['status'] = '保存失败'
            else:
                public_method.Opratings_log(request.user,
                                          'change user {} password'.format(user),
                                          datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                          )

    return JsonResponse(msg)


