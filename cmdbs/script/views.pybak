@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def recv_file(request):
    if request.method == 'POST':
        data = request.FILES.get('filename', None)
        ipa_name = request.POST.get('ipaname', None)
        res = public_method.get_servers_info('web-ftp', 'web-ftp-machine')
        ip = res.split()[0]
        port = res.split()[-1]
        user = res.split()[1]
        passwed = res.split()[2]
        msg = {'status': 'success',
               'md5': ''
               }
        if data:
            paths = '/opt/packages'
            files = paths + os.sep + data.name
            ipaname = paths + os.sep + ipa_name
            with open(files, 'wb') as f:
                for i in data.chunks():  # chunks()防止内存被占满
                    f.write(i)
            os.rename(files, ipaname)
            msg['md5'] = hashlib.md5(open(ipaname, 'rb').read()).hexdigest()
            ftp = ftplib.FTP()
            ftp.set_pasv(False)
            ftp.encoding = 'utf-8'
            try:
                ftp.connect(ip, int(port), timeout=10)
                ftp.login(user, passwed)
            except (socket.timeout, ftplib.error_perm):
                msg['status'] = 'ftp connect error.'
            else:
                try:
                    ftp.storbinary('STOR ' + ipa_name,
                                   open(ipaname, 'rb'))
                    time.sleep(0.5)
                except ftplib.error_perm:
                    msg['status'] = 'Transfer file failed.'
        return JsonResponse(msg)


def servers_api(request):  # ip获取的api接口
    if request.method == 'GET':
        mails = {'dep': '120332269@qq.com', 'opra': '15889709122@qq.com'}
        para_key = 'cmdb'
        msg = {'res': -1, 'message': 'para error or para type error'}
        key_list = [hashlib.md5((para_key+'-'+v).encode()).hexdigest() for k, v in mails.items()]
        key = request.GET.get('key', None)
        name = request.GET.get('name', None)
        servers = request.GET.get('item', None)
        if all([key, name, servers]):
            try:
                key = json.loads(key)
                name = json.loads(name)
                servers = json.loads(servers)
            except ValueError:
                msg['message'] = 'Parameter type error.'
                return JsonResponse(msg)
            if str(key) in key_list and str(name) == 'lxb' and str(servers) == 'servers':
                data = {'res': ''}
                ip_dict = Servers.objects.filter(id__gte=0).values('ip')
                ip = [i.get('ip') for i in ip_dict]
                data['res'] = ip
                return JsonResponse(data)
            else:
                msg['message'] = 'Verification failed.'
                return JsonResponse(msg)
        else:
            msg['message'] = 'Miss parameter.'
            return JsonResponse(msg)
    return HttpResponse("<h1>404<h1>")

