@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def group_edit_permissions(request):
    msg = {'status': 'success'}
    res = []
    perm_data = request.POST.get('content', None)
    perm_data = json.loads(perm_data)
    group_name = request.POST.get('groups', None)
    group_perm_opra = Group.objects.get(name=group_name)
    group_perm = Group.objects.get(name=group_name).permissions.values('codename')
    group_ori_perm = [i.get('codename') for i in group_perm]
    for a_item in perm_data:
        if a_item not in group_ori_perm:
            add_p = Permission.objects.get(codename=a_item)
            group_perm_opra.permissions.add(add_p)
            if not group_perm_opra.permissions.filter(codename=a_item):
                res.append(a_item)
    for d_item in group_ori_perm:
        if d_item not in perm_data:
            del_p = Permission.objects.get(codename=d_item)
            group_perm_opra.permissions.remove(del_p)
            if group_perm_opra.permissions.filter(codename=d_item):
                res.append(d_item)
    if res.__len__() != 0:
        msg['status'] = "change group'permission failed."
    return JsonResponse(msg)


