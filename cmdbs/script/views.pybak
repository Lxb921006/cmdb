@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def userinfo(request):
    us = request.POST.get('user', None)
    user_type = {}
    msg = {'status': 'success'}
    u = User.objects.get(username=us)
    u_info = User.objects.filter(username=us).values('email', 'is_active', 'date_joined')
    if u.groups.values('name').__len__() != 0:
        types = u.groups.values('name')[0]['name']
        user_type['email'] = u_info[0].get('email', None)
        user_type['user_type'] = types
        if u_info[0].get('is_active', None):
            user_type['is_active'] = '启用'
        else:
            user_type['is_active'] = '停用'
        user_type['date_joined'] = u_info[0].get('date_joined', None)
    else:
        msg['status'] = 'failed.'
    return JsonResponse({'msg': msg, 'data': user_type})


