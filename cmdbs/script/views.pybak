@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def check_permissions(request):  # 这里是查看对应用户已经有的权限
    types = ''
    user = request.POST.get('user', None)
    u = User.objects.get(username=user)
    if u.groups.values('name').__len__() != 0:
        types = u.groups.values('name')[0]['name']
    user_permis = User.objects.get(username=user).get_all_permissions()
    user_permis_list = [item.split('.')[-1] for item in user_permis]
    return JsonResponse({'user_perms': user_permis_list, 'user_type': types})


@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def add_del_permissions(request):  # 这里是添加,删除对应用户的权限
    app_name = 'cmdbs.'
    add_perms = list()
    del_perms = list()
    all_perms = list()
    flag = True
    msg = {'status': 'success'}
    data = request.POST.get('content', None)
    user = request.POST.get('user', None)
    check_user = User.objects.get(username=user)
    all_premissions = Permission.objects.values()
    user_permis = User.objects.get(username=user).get_all_permissions()
    user_permis_list = [item.split('.')[-1] for item in user_permis]
    for all_perms_data in all_premissions:
        all_perms.append(all_perms_data.get('codename', None))
    for recv_data in json.loads(data):
        if not check_user.has_perm(app_name+recv_data):
            if recv_data in all_perms:
                add_p = Permission.objects.get(codename=recv_data)
                User.objects.get(username=user).user_permissions.add(add_p)
                public_method.Opratings_log(request.user,
                                          '{} add permissions {}'.format(user, add_p),
                                          datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                          )
            else:
                msg['status'] = '请在后台先添加好对应权限.'
    for db_data in user_permis_list:
        if db_data not in json.loads(data):
            del_perms.append(db_data)
    if len(del_perms) > 0:
        flag = False
    for del_perms_data in del_perms:
        del_p = Permission.objects.get(codename=del_perms_data)
        User.objects.get(username=user).user_permissions.remove(del_p)
        public_method.Opratings_log(request.user,
                                  '{} remove permissions {}'.format(user, del_p),
                                  datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                                  )
    add_perms.clear()
    del_perms.clear()
    all_perms.clear()
    return JsonResponse(msg)


