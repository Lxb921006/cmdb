@login_required(login_url='/cmdb/is_login/')
@csrf_exempt
def page_record_operation_log(request):
    recv_cur_page_number = request.POST.get('cur_page', None)
    recv_change_page_number = request.POST.get('change_page_number', None)
    search_data = request.POST.get('search_data', None)
    jump_page = request.POST.get('jump_page', None)
    begin_date = request.POST.get('begin_date', None)
    end_date = request.POST.get('end_date', None)
    data_list = list()
    show_datas = None
    all_datas_count = None
    pages = None
    change_page_number = common.try_int(recv_change_page_number, 10)

    if all([recv_cur_page_number, recv_change_page_number]):
        if begin_date and not end_date:
            start_time = datetime.datetime.strptime(begin_date, "%Y-%m-%d")
            all_datas_count = record_log.objects.filter(
                                                        Q(operation_record__icontains=search_data) |
                                                        Q(login_user__icontains=search_data),
                                                        date__gte=start_time
                                                        ).count()
            if all_datas_count == 0:
                all_datas_count = 1
            pages = divmod(all_datas_count, change_page_number)
            if pages[1] == 0:
                pages = pages[0]
            else:
                pages = pages[0] + 1
